# ─────────────────────────────────────────────────────────────────────────────
#  Bot Deployment API Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  On Replit: use the Secrets panel instead of a .env file.
# ─────────────────────────────────────────────────────────────────────────────

# Port the API server listens on (default: 8080)
PORT=8080

# Secret key that authenticates all API requests.
# Must match the $API_SECRET value in your PHP files (deploy.php, manage.php).
API_SECRET_KEY=your-strong-secret-here

# Deployment platform API key (obtain from your platform account settings)
# You can also set this via the Admin Settings panel in the PHP dashboard.
HEROKU_API_KEY=

# (Optional) Deploy to a team/organization account.
# Leave blank to deploy to your personal account.
# You can also set this via the Admin Settings panel.
HEROKU_TEAM=

# Node environment
NODE_ENV=production
